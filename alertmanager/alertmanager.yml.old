# Alertmanager Configuration for SSL Certificate Alerts
# Save this to: alertmanager/alertmanager.yml

global:
  # Email notification configuration
  smtp_smarthost: 'smtp.gmail.com:587'
  smtp_from: 'alertmanager@example.com'
  smtp_auth_username: 'your-email@gmail.com'
  smtp_auth_password: 'your-app-password'
  smtp_require_tls: true

# Route alerts based on severity and type
route:
  group_by: ['alertname', 'severity', 'env']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 12h
  receiver: 'default'
  routes:
    # Critical alerts - immediate notification via DingTalk/Lark
    - match:
        severity: 'critical'
      receiver: 'critical-alerts'

    # Warning alerts - email notification
    - match:
        severity: 'warning'
      receiver: 'warning-alerts'

receivers:
  # Default receiver - log only
  - name: 'default'
    webhook_configs:
      - url: 'http://localhost:8080/webhook'

  # Critical alerts - DingTalk/Lark/Slack
  - name: 'critical-alerts'
    webhook_configs:
      # DingTalk webhook
      - url: 'https://oapi.dingtalk.com/robot/send?access_token=YOUR_DINGTALK_TOKEN'
        send_resolved: true
      # Lark (Feishu) webhook
      - url: 'http://ssl-dashboard:80/api/webhooks/lark'
        send_resolved: true

  # Warning alerts - Email
  - name: 'warning-alerts'
    email_configs:
      - to: 'team@example.com'
        headers:
          subject: 'SSL Certificate Warning Alert'
        send_resolved: true

# Inhibit rules - suppress lower priority alerts if higher priority is firing
inhibit_rules:
  # Inhibit warning if critical is already firing for the same alert
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname']
