# Agent 配置
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# =============================================================================
# 必填配置
# =============================================================================

# Agent 监听地址（Server 会从此地址拉取数据）
AGENT_LISTEN_HOST=0.0.0.0

# Agent 监听端口（Server 会访问此端口）
AGENT_LISTEN_PORT=48091

# =============================================================================
# Agent 身份信息（用于前端显示）
# =============================================================================

# Agent 唯一标识（用于 Server 识别和目标分配）
# 如果不填写，Server 会自动生成
AGENT_ID=

# Agent 显示名称（前端显示的主机名，如：内网机房Agent、生产环境Agent）
AGENT_HOSTNAME=内网机房Agent

# Agent IP 地址（前端显示的 IP，建议填写宿主机真实 IP）
# 如果不填写，Agent 会自动尝试获取
AGENT_IP=10.0.0.1

# =============================================================================
# 可选配置
# =============================================================================

# 证书检测间隔 (秒)，默认 180 秒
SCRAPE_INTERVAL=180

# 连接超时 (秒)，默认 30 秒
SCRAPE_TIMEOUT=30

# 目标配置文件路径
AGENT_TARGETS_PATH=/app/data/targets.json
