# SSL Certificate Agent 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ========== Agent 监听配置 ==========
# Agent 监听的地址和端口，Server 通过此地址拉取数据
AGENT_LISTEN_HOST=0.0.0.0
AGENT_LISTEN_PORT=8091

# ========== Agent 身份标识 ==========
# 用于 Server 识别此 Agent，建议使用唯一标识
# 如果不设置，Agent 会自动生成
AGENT_ID=agent-001

# Agent 主机名和 IP（可选，不设置会自动获取）
# AGENT_HOSTNAME=agent-server-01
# AGENT_IP=203.0.113.1

# ========== Server 连接配置 ==========
# Server 的地址（必须设置）
# Server 端需要监听 0.0.0.0 或允许 Agent 访问的地址
SERVER_URL=http://127.0.0.1:8090

# 目标同步间隔（秒），Agent 定期从 Server 获取最新的目标配置
SYNC_INTERVAL=60

# ========== 检测配置 ==========
# SSL 证书检测间隔（秒）
SCRAPE_INTERVAL=180

# SSL 连接超时时间（秒）
SCRAPE_TIMEOUT=30

# ========== 数据存储 ==========
# 目标配置文件路径
AGENT_TARGETS_PATH=/app/data/targets.json
