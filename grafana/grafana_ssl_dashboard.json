  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "type": "table",
      "title": "SSL 证书详细信息",
      "description": "显示所有监控的SSL证书详细信息，包括URL、有效期、发行机构和负责人",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ssl_cert_days_left",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 7
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 365
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "unit",
                "value": "d"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      }
    },
    {
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "type": "bargauge",
      "title": "证书剩余有效期（天）",
      "description": "显示各证书剩余有效天数，红色表示已过期或即将过期",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ssl_cert_days_left",
          "legendFormat": "{{hostname}}:{{port}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 365,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "unit": "d"
        }
      }
    },
    {
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "type": "piechart",
      "title": "证书状态分布",
      "description": "按状态显示证书分布：正常（>30天）、警告（7-30天）、严重（<7天）、已过期",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_days_left > 30) or vector(0)",
          "legendFormat": "正常 (>30天)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_days_left >= 7 and ssl_cert_days_left <= 30) or vector(0)",
          "legendFormat": "警告 (7-30天)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_days_left > 0 and ssl_cert_days_left < 7) or vector(0)",
          "legendFormat": "严重 (<7天)",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_days_left <= 0) or vector(0)",
          "legendFormat": "已过期",
          "refId": "D"
        }
      ],
      "options": {
        "pieType": "donut",
        "showValues": "auto"
      }
    },
    {
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "type": "table",
      "title": "即将过期的证书（<30天）",
      "description": "列出所有在30天内即将过期的SSL证书",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ssl_cert_days_left < 30 and ssl_cert_check_success == 1",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "darkred",
                "value": 0
              },
              {
                "color": "red",
                "value": 7
              },
              {
                "color": "orange",
                "value": 30
              }
            ]
          }
        }
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Value"
          }
        ]
      }
    },
    {
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "type": "stat",
      "title": "证书统计",
      "description": "显示证书总数、正常、警告、严重状态的数量",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_check_success == 1)",
          "legendFormat": "总数",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_days_left > 30)",
          "legendFormat": "正常",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_days_left >= 7 and ssl_cert_days_left <= 30)",
          "legendFormat": "警告",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(ssl_cert_days_left < 7)",
          "legendFormat": "严重",
          "refId": "D"
        }
      ],
      "options": {
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "type": "bargauge",
      "title": "按负责人分布",
      "description": "显示各负责人管理的证书数量及状态",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count by (owner) (ssl_cert_days_left)",
          "legendFormat": "{{owner}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "auto",
        "showUnfilledAreas": true,
        "textMode": "auto"
      }
    }
  ],
