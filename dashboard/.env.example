# Dashboard 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ==================== 登录认证配置 ====================
# 自定义管理员用户名
VITE_ADMIN_USERNAME=admin

# 自定义管理员密码
VITE_ADMIN_PASSWORD=admin123

# ==================== 验证码服务配置 ====================
# 验证码服务API地址（Docker容器内部地址）
VITE_CAPTCHA_API_URL=http://ssl-captcha-service:3001

# 注意：Metrics 和 Alerts API 已通过 Nginx 反向代理
# 前端通过 /api/metrics 和 /api/alerts 访问，无需配置

# ==================== Agent Server 配置 ====================
# Agent Server 地址（用于目标管理）
VITE_AGENT_SERVER_URL=http://127.0.0.1:8090
