# ===========================================
# SSL Certificate Monitoring System - 配置示例
# ===========================================
# 复制此文件为 .env 并填写实际值
# 注意: .env 文件包含敏感信息，不要提交到版本控制

# ===== Grafana 配置 =====
GRAFANA_ADMIN_USER=gfadmin
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# ===== Dashboard Admin 配置 =====
DASHBOARD_ADMIN_USER=gsadmin
DASHBOARD_ADMIN_PASSWORD=your_dashboard_password

# ===== 飞书 Webhook 配置 =====
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_ID
FEISHU_SEND_RESOLVED=true

# ===== 邮件告警 SMTP 配置 =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your_email@example.com
SMTP_USE_TLS=true

# ===== AlertManager SMTP 配置（用于直接邮件告警，可选） =====
ALERT_SMTP_SMARTHOST=smtp.example.com:587
ALERT_SMTP_FROM=your_email@example.com
ALERT_SMTP_AUTH_USERNAME=your_email@example.com
ALERT_SMTP_AUTH_PASSWORD=your_smtp_password
ALERT_SMTP_REQUIRE_TLS=true
